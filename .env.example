# QDRANT SETTINGS
# Host for Qdrant vector database (e.g., localhost or qdrant)
QDRANT_HOST=localhost
# Port for Qdrant REST API
QDRANT_PORT=6333
# Name of the Qdrant collection to use
QDRANT_COLLECTION_NAME=lexrag_docs
# Vector dimension (1024 for BGE-M3)
QDRANT_VECTOR_SIZE=1024

# NEO4J SETTINGS
# URI for Neo4j database (bolt://localhost:7687)
NEO4J_URI=bolt://localhost:7687
# Username for Neo4j
NEO4J_USERNAME=neo4j
# Password for Neo4j
NEO4J_PASSWORD=lexragpassword

# REDIS SETTINGS
# Redis URL for caching, rate limiting and celery (redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# GROQ SETTINGS
# API Key for Groq
GROQ_API_KEY=your_groq_api_key_here

# Model to use for generation (e.g. llama3-70b-8192)

# Generation temperature
GROQ_TEMPERATURE=0.0
# Max tokens to generate
GROQ_MAX_TOKENS=2048

# OLLAMA SETTINGS
# Base URL for Ollama local server
OLLAMA_BASE_URL=http://localhost:11434
# Embedding model to use
OLLAMA_EMBEDDING_MODEL=bge-m3
# Reranker model (cross-encoder via sentence-transformers, not Ollama)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# LANGSMITH SETTINGS
# LangSmith tracing enable
LANGCHAIN_TRACING_V2=true
# LangSmith API Key
LANGCHAIN_API_KEY=your_langsmith_api_key
# LangSmith Project Name
LANGCHAIN_PROJECT=lexrag

# ARIZE PHOENIX SETTINGS
# Endpoint for Phoenix OTEL collector
ARIZE_ENDPOINT=http://localhost:6006/v1/traces

# APPLICATION SETTINGS
# Environment (development or production)
APP_ENVIRONMENT=development
# Log level (DEBUG, INFO, WARNING, ERROR)
APP_LOG_LEVEL=INFO
# Max file size in MB for ingestion
APP_MAX_FILE_SIZE_MB=50
# Supported file extensions for ingestion
APP_SUPPORTED_EXTENSIONS=.pdf,.docx,.pptx,.xlsx,.html,.md
